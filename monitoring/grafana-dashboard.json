{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "KavachOS metrics source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "KavachOS three-layer runtime governance — kernel + posture + ledger",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Layer 1 — Kernel (seccomp + Falco)",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(kavachos_kernel_violations_total[5m])",
          "legendFormat": "violations/sec"
        }
      ],
      "title": "Kernel Violations/sec",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "kavachos_kernel_active_sessions",
          "legendFormat": "sessions"
        }
      ],
      "title": "Active Sessions",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "kavachos_kernel_hil_gates_active",
          "legendFormat": "HIL gates"
        }
      ],
      "title": "HIL Gates Active (depth≥4)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "increase(kavachos_kernel_profiles_generated_total[1h])",
          "legendFormat": "profiles/hr"
        }
      ],
      "title": "Profiles Generated (1h)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "id": 5,
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(kavachos_kernel_violations_total[5m]) by (severity)",
          "legendFormat": "{{severity}}"
        }
      ],
      "title": "Violations by Severity",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "id": 6,
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(kavachos_kernel_violations_total[5m]) by (domain)",
          "legendFormat": "{{domain}}"
        }
      ],
      "title": "Violations by Domain",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "id": 7,
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "kavachos_kernel_depth_distribution",
          "legendFormat": "depth {{depth}}"
        }
      ],
      "title": "Active Sessions by Delegation Depth",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Layer 2 — Proxy (budget + token governance)",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "percentage", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "kavachos_proxy_daily_spend_usd",
          "legendFormat": "spend"
        }
      ],
      "title": "Daily Spend (USD)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 18 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "kavachos_proxy_budget_percent_used * 100",
          "legendFormat": "% used"
        }
      ],
      "title": "Budget % Used",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 10,
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.99, rate(kavachos_proxy_request_duration_ms_bucket[5m]))",
          "legendFormat": "p99"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.50, rate(kavachos_proxy_request_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "title": "Proxy Latency (p50/p99)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "id": 11,
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(kavachos_proxy_requests_total[5m]) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "title": "Proxy Requests/sec by Model",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 24 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "increase(kavachos_proxy_budget_breaches_total[24h])",
          "legendFormat": "breaches"
        }
      ],
      "title": "Budget Breaches (24h)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 24 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "increase(kavachos_proxy_dan_gates_total[1h])",
          "legendFormat": "DAN gates"
        }
      ],
      "title": "DAN Gates (1h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "title": "Layer 3 — Ledger (PRAMANA receipts + chain integrity)",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 31 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "kavachos_ledger_chain_intact",
          "legendFormat": "chain OK"
        }
      ],
      "title": "Chain Integrity",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 31 },
      "id": 15,
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(kavachos_ledger_receipts_total[5m])",
          "legendFormat": "receipts/sec"
        }
      ],
      "title": "Receipt Rate",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 35 },
      "id": 16,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "increase(kavachos_ledger_depth_regressions_total[1h])",
          "legendFormat": "depth regressions"
        }
      ],
      "title": "Depth Regressions (1h)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 31 },
      "id": 17,
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "kavachos_ledger_receipts_total by (delegation_depth)",
          "legendFormat": "depth {{delegation_depth}}"
        }
      ],
      "title": "Receipts by Delegation Depth",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "tags": ["kavachos", "ai-governance", "seccomp", "ankr"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(kavachos_kernel_violations_total, session_id)",
        "label": "Session",
        "name": "session",
        "options": [],
        "query": "label_values(kavachos_kernel_violations_total, session_id)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "KavachOS — Runtime Governance",
  "uid": "kavachos-main-v1",
  "version": 1
}
